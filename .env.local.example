# ─────────────────────────────────────────────────────────────
# .env.local — copy this file to .env.local and fill in values
# NEVER commit .env.local to Git
# ─────────────────────────────────────────────────────────────

# From: sanity.io → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_SANITY_DATASET=production

# From: sanity.io → your project → API → Tokens → Add Token (Editor role)
# Used only in the upload script — never exposed to the browser
SANITY_WRITE_TOKEN=your-write-token-here

# Your site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Resend API key for contact form (create at https://resend.com/dashboard/api-keys)
RESEND_API_KEY=your-resend-api-key-here
# Resend audience for contact form (create at https://resend.com/dashboard/audiences)
RESEND_AUDIENCE_ID=your-resend-audience-id-here
